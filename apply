#!/usr/bin/env bash
# One-word entry point: discover -> score -> apply until the daily goal.
#
#   ./apply         run the full daily-apply pipeline
#   ./apply -v      same, with INFO logging
#
# Config lives in config.json (goal, thresholds); profile in profile.json.
set -e
cd "$(dirname "$0")"
PY="python3"
[ -x .venv/bin/python ] && PY=".venv/bin/python"
exec "$PY" -m jobagent "$@" daily-apply
